rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Pacientes: lectura y escritura libre (red local clínica)
    match /pacientes/{docId} {
      allow read, write: if true;
    }
    // Agenda diaria
    match /agenda/{fecha} {
      allow read, write: if true;
    }
  }
}
